# Copy to repo root as `.env` (never commit `.env`)
APP_ENV=development
HTTP_ADDR=:8080

# Primary path: Neon (cloud Postgres). Paste your Neon connection string here.
# Example: postgres://user:pass@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgres://USER:PASSWORD@HOST/DB?sslmode=require

# Redis optional for now (API belum pakai). Isi nanti kalau pakai Upstash/Redis cloud.
REDIS_URL=

# Change this before any shared/staging deploy
JWT_SECRET=dev-only-change-me-ilo-super-secret-key
JWT_TTL_HOURS=72
